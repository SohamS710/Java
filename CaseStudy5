import java.util.*;

abstract class Transport {
    protected String trackingId;
    protected String destination;

    public Transport(String trackingId, String destination) {
        this.trackingId = trackingId;
        this.destination = destination;
    }

    public abstract void dispatch();
}

interface GPS {
    void getCoordinates();
}

interface Autonomous {
    void selfDrive();
}

class Truck extends Transport {
    public Truck(String trackingId, String destination) {
        super(trackingId, destination);
    }
    
    @Override
    public void dispatch() {
        System.out.println("Truck " + trackingId + " heading to " + destination);
    }
}

class DeliveryDrone extends Transport implements GPS, Autonomous {
    public DeliveryDrone(String trackingId, String destination) {
        super(trackingId, destination);
    }

    @Override
    public void dispatch() {
        System.out.println("Drone " + trackingId + " taking off to " + destination);
    }
    
    @Override
    public void getCoordinates() {
        System.out.println("Coordinates: 40.7128° N, 74.0060° W");
    }

    @Override
    public void selfDrive() {
        System.out.println("Drone is flying autonomously...");
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        List<Transport> transports = new ArrayList<>();

        System.out.print("Enter number of transports: ");
        int n = sc.nextInt();
        sc.nextLine();

        for (int i = 0; i < n; i++) {

            System.out.println("\nEnter type (truck/drone): ");
            String type = sc.nextLine().toLowerCase();

            System.out.print("Enter Tracking ID: ");
            String id = sc.nextLine();

            System.out.print("Enter Destination: ");
            String dest = sc.nextLine();

            if (type.equals("truck")) {
                transports.add(new Truck(id, dest));
            } else if (type.equals("drone")) {
                transports.add(new DeliveryDrone(id, dest));
            } else {
                System.out.println("Invalid type! Skipping...");
            }
        }

        System.out.println("\n--- Dispatching All Transports ---");

        for (Transport t : transports) {

            t.dispatch(); // polymorphism

            if (t instanceof GPS) {
                ((GPS) t).getCoordinates();
            }

            if (t instanceof Autonomous) {
                ((Autonomous) t).selfDrive();
            }

            System.out.println();
        }

        sc.close();
    }
}
