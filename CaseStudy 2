class Employee {
    protected String name;
    protected double baseSalary;

    public Employee(String name, double baseSalary) {
        this.name = name;
        this.baseSalary = baseSalary;
    }

    public double calculateSalary() {
        return baseSalary + (0.05 * baseSalary); // 5% allowance
    }
}

class Manager extends Employee {

    public Manager(String name, double baseSalary) {
        super(name, baseSalary);
    }

    @Override
    public double calculateSalary() {
        double salary = super.calculateSalary(); // Employee logic
        salary += 2000; // management bonus
        return salary;
    }
}

class Executive extends Manager {

    public Executive(String name, double baseSalary) {
        super(name, baseSalary);
    }

    @Override
    public double calculateSalary() {
        double salary = super.calculateSalary(); // Manager logic
        salary += 0.10 * baseSalary; // 10% incentive on base
        return salary;
    }
}

public class Main {
    public static void main(String[] args) {

        Employee e1 = new Employee("Alice", 10000);
        System.out.printf("TC1 Output: %.2f\n", e1.calculateSalary()); // 10500.00

        Employee e2 = new Manager("Bob", 10000);
        System.out.printf("TC2 Output: %.2f\n", e2.calculateSalary()); // 12500.00

        Employee e3 = new Executive("Charlie", 10000);
        System.out.printf("TC3 Output: %.2f\n", e3.calculateSalary()); // 13500.00
    }
}
