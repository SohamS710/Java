abstract class Payment {
    private double transactionId;
    protected double amount;

    public Payment(double transactionId, double amount) {
        this.transactionId = transactionId;
        this.amount = amount;
    }

    // Getter (Encapsulation)
    public double getTransactionId() {
        return transactionId;
    }

    // Abstract method
    public abstract double processPayment();
}

class CreditCardPayment extends Payment {

    public CreditCardPayment(double transactionId, double amount) {
        super(transactionId, amount);
    }

    @Override
    public double processPayment() {
        return amount + (0.02 * amount); // 2% fee
    }
}

class UPIPayment extends Payment {

    public UPIPayment(double transactionId, double amount) {
        super(transactionId, amount);
    }

    @Override
    public double processPayment() {
        return amount; // no fee
    }
}

// Polymorphism demo class
class PaymentProcessor {

    public static void process(Payment p) {
        System.out.println("Processed Amount: " + p.processPayment());
    }
}

public class Main {
    public static void main(String[] args) {

        // TC1
        Payment p1 = new CreditCardPayment(101, 1000);
        System.out.println("TC1 Output: " + p1.processPayment()); // 1020

        // TC2
        Payment p2 = new UPIPayment(102, 1000);
        System.out.println("TC2 Output: " + p2.processPayment()); // 1000

        // TC3 (Polymorphic Array)
        Payment[] payments = {
            new CreditCardPayment(103, 1000),
            new UPIPayment(104, 1000)
        };

        double total = 0;
        for (Payment p : payments) {
            total += p.processPayment();
        }

        System.out.println("TC3 Total: " + total); // 2020
    }
}
